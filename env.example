# UPS API (required)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ENV=prod

# PostNL API (optional)
POSTNL_API_KEY=
POSTNL_ENV=sandbox

# Chronopost / La Poste API (optional, get key at https://developer.laposte.fr)
LAPOSTE_API_KEY=

# DPD: no API key needed (public API)

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# UPS Track Alert webhook (optional)
TRACK_ALERT_WEBHOOK_URL=
TRACK_ALERT_WEBHOOK_CREDENTIAL=

# Server
PORT=8080
